rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the user authenticated?
    function isAuth() {
      return request.auth != null;
    }

    // Suggestions: anyone can write (anonymous form), only auth users can read
    match /suggestions/{id} {
      allow create: if true; // public anonymous submission
      allow read, update, delete: if isAuth();
    }

    // All other collections: only authenticated users
    match /tasks/{id} {
      allow read, write: if isAuth();
    }
    match /announcements/{id} {
      allow read, write: if isAuth();
    }
    match /onboarding/{id} {
      allow read, write: if isAuth();
    }
    match /offboarding/{id} {
      allow read, write: if isAuth();
    }
    match /users/{id} {
      allow read: if isAuth() && request.auth.uid == id;
      allow write: if false; // only Firebase Admin can write user roles
    }
  }
}
