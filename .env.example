# ─── Firebase (Client-side) ───────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (Server-side — never expose to browser) ──────────────────
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=   # full PEM key, include \n characters

# ─── Google APIs (single dedicated Google account) ───────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEETS_ID=              # the ID from your Google Sheet URL
GOOGLE_CALENDAR_ID=            # HR admin calendar ID (usually email@gmail.com)

# ─── Resend (Email service) ───────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hr@cynapto.com   # verified sending domain

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://cynapto-hr.vercel.app
CRON_SECRET=                   # random secret to protect /api/reminders cron endpoint

# ─── Admin Credentials (set once in Firebase Console) ────────────────────────
# HR_ADMIN_EMAIL and MANAGER_EMAIL are set in Firebase Auth — not needed here
